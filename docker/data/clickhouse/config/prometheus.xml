<?xml version="1.0"?>
<!-- Expose ClickHouse's native Prometheus metrics on :9363 (replaces the removed
     clickhouse-exporter). Scraped by Prometheus as job 'clickhouse' over the
     shared `proxy` network. Mounted at /etc/clickhouse-server/config.d/prometheus.xml.

     listen_host override: the base image (docker_related_config.xml) sets listen_host
     to "::" then "0.0.0.0". This container has IPv6 disabled, so "::" fails; the main
     ports fall through to 0.0.0.0, but the Prometheus server binds only the first
     listen_host and never came up. Replace the list with 0.0.0.0 so :9363 binds. -->
<clickhouse>
    <listen_host replace="replace">0.0.0.0</listen_host>
    <prometheus>
        <endpoint>/metrics</endpoint>
        <port>9363</port>
        <metrics>true</metrics>
        <events>true</events>
        <asynchronous_metrics>true</asynchronous_metrics>
        <errors>true</errors>
    </prometheus>
</clickhouse>
