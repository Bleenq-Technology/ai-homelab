# ============================================================================
# Homelab shared environment — copy to .env and fill in real values on jarvis.
#   cp docker/.env.example docker/.env
# High-value credentials (EasyDNS API, etc.) live in docker/secrets/, NOT here.
# Every password below ships as a placeholder — change ALL of them before use.
# ============================================================================

# ---- Global ----------------------------------------------------------------
DOMAIN=pdx.sanctioned.tech
TZ=America/Los_Angeles
# ACME / Let's Encrypt registration email (cert expiry notices)
ACME_EMAIL=paul.vilevac@bleenq.com

# ---- Traefik ---------------------------------------------------------------
# Dashboard basic-auth user. Generate the hash with:  htpasswd -nbB admin 'pass'
# Escape every $ as $$ when pasting into .env (compose interpolation).
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$REPLACE_WITH_BCRYPT_HASH

# ---- Postgres (unified, service host = "postgres") -------------------------
POSTGRES_SUPERUSER=postgres
POSTGRES_PASSWORD=change_me_superuser
# Per-service databases + roles (created by data/postgres init script)
KEYCLOAK_DB_PASSWORD=change_me_keycloak
NETBOX_DB_PASSWORD=change_me_netbox
INFISICAL_DB_PASSWORD=change_me_infisical
BASEROW_DB_PASSWORD=change_me_baserow
LANGFUSE_DB_PASSWORD=change_me_langfuse
MLFLOW_DB_PASSWORD=change_me_mlflow

# ---- Redis -----------------------------------------------------------------
REDIS_PASSWORD=change_me_redis

# ---- MinIO (S3) ------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio_min8chars
# Bucket auto-created for Langfuse on startup
LANGFUSE_S3_BUCKET=langfuse

# ---- ClickHouse ------------------------------------------------------------
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=change_me_clickhouse

# ---- Keycloak (admin bootstrap) --------------------------------------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_keycloak_admin

# ---- Grafana ---------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana

# ---- Firezone (VPN) — generate strong randoms (openssl rand -base64 32) -----
FIREZONE_ADMIN_EMAIL=admin@pdx.sanctioned.tech
FIREZONE_ADMIN_PASSWORD=change_me_firezone
FIREZONE_SECRET_KEY_BASE=change_me_64_hex
FIREZONE_LIVE_VIEW_SIGNING_SALT=change_me_salt
FIREZONE_COOKIE_SIGNING_SALT=change_me_salt
FIREZONE_COOKIE_ENCRYPTION_SALT=change_me_salt
FIREZONE_OIDC_CLIENT_SECRET=change_me_from_keycloak

# ---- AI service secrets ----------------------------------------------------
OLLAMA_BASE_URL=http://jarvis:11434
N8N_ENCRYPTION_KEY=change_me_n8n_key
FLOWISE_USERNAME=admin
FLOWISE_PASSWORD=change_me_flowise
FLOWISE_SECRETKEY=change_me_flowise_secret
QDRANT_API_KEY=change_me_qdrant
NEO4J_PASSWORD=change_me_neo4j
SEARXNG_SECRET=change_me_searxng
LANGFUSE_NEXTAUTH_SECRET=change_me_langfuse_nextauth
LANGFUSE_SALT=change_me_langfuse_salt
LANGFUSE_ENCRYPTION_KEY=change_me_64_hex

# ---- Per-service admin/login & extras (services with built-in defaults) ----
NETBOX_ADMIN_EMAIL=admin@pdx.sanctioned.tech
NETBOX_ADMIN_PASSWORD=change_me_netbox_admin
PGADMIN_EMAIL=admin@pdx.sanctioned.tech
PGADMIN_PASSWORD=change_me_pgadmin
BASEROW_SECRET_KEY=change_me_baserow_secret
FIREZONE_DB_PASSWORD=change_me_firezone_db
INFISICAL_ENCRYPTION_KEY=change_me_infisical_enc_16b_hex
INFISICAL_AUTH_SECRET=change_me_infisical_auth_b64

# ---- AdGuard (admin is set in its first-run wizard; exporter logs in with these) ----
ADGUARD_USERNAME=admin
ADGUARD_PASSWORD=change_me_adguard
# DNS binds to this host IP only (host systemd-resolved holds 127.0.0.53:53)
ADGUARD_DNS_IP=192.168.2.10

# ---- AI LLM backend (local unsloth on the host, OpenAI-compatible :8888) ----
HOST_LAN_IP=192.168.2.10
UNSLOTH_API_KEY=sk-unsloth-replace_me

# ---- LiteLLM gateway (fronts unsloth) + Langfuse project keys (LLM tracing) ----
LITELLM_MASTER_KEY=sk-change_me
LANGFUSE_PUBLIC_KEY=pk-lf-from_langfuse_ui
LANGFUSE_SECRET_KEY=sk-lf-from_langfuse_ui

# ---- Keycloak SSO — OIDC client secrets (generated in Keycloak; see core/keycloak/README.md) ----
# forward-auth bridge: traefik-forward-auth (Keycloak client "oauth2-proxy")
OAUTH2_PROXY_CLIENT_SECRET=set_from_keycloak
OAUTH2_PROXY_COOKIE_SECRET=change_me_32_char_string
TFA_SECRET=change_me_random_hex
# native OIDC clients
GRAFANA_OIDC_CLIENT_SECRET=set_from_keycloak
OPENWEBUI_OIDC_CLIENT_SECRET=set_from_keycloak
PORTAINER_OIDC_CLIENT_SECRET=set_from_keycloak
LANGFUSE_OIDC_CLIENT_SECRET=set_from_keycloak
