{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "title": "ClickHouse",
  "uid": "clickhouse-homelab",
  "tags": ["homelab", "clickhouse", "data"],
  "timezone": "browser",
  "schemaVersion": 39,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": { "list": [] },
  "panels": [
    {
      "type": "stat", "title": "Status", "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "up{job=\"clickhouse\"}", "refId": "A" } ],
      "fieldConfig": { "defaults": { "mappings": [ { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } } ], "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] } } },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat", "title": "Uptime", "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "ClickHouseAsyncMetrics_Uptime", "refId": "A" } ],
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "fixed", "fixedColor": "text" } } },
      "options": { "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat", "title": "Active queries", "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "ClickHouseMetrics_Query", "refId": "A" } ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 20 }, { "color": "red", "value": 50 } ] } } },
      "options": { "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat", "title": "Memory (tracked)", "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "ClickHouseMetrics_MemoryTracking", "refId": "A" } ],
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "options": { "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat", "title": "Disk used", "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "100 * ClickHouseAsyncMetrics_DiskUsed_default / ClickHouseAsyncMetrics_DiskTotal_default", "refId": "A" } ],
      "fieldConfig": { "defaults": { "unit": "percent", "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 75 }, { "color": "red", "value": 90 } ] } } },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat", "title": "Failed queries (5m)", "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "increase(ClickHouseProfileEvents_FailedQuery[5m])", "refId": "A" } ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } } },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "timeseries", "title": "Queries / sec", "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "qps", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [
        { "expr": "rate(ClickHouseProfileEvents_Query[5m])", "legendFormat": "all", "refId": "A" },
        { "expr": "rate(ClickHouseProfileEvents_SelectQuery[5m])", "legendFormat": "select", "refId": "B" },
        { "expr": "rate(ClickHouseProfileEvents_InsertQuery[5m])", "legendFormat": "insert", "refId": "C" },
        { "expr": "rate(ClickHouseProfileEvents_FailedQuery[5m])", "legendFormat": "failed", "refId": "D" }
      ]
    },
    {
      "type": "timeseries", "title": "Rows / sec", "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "rps", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [
        { "expr": "rate(ClickHouseProfileEvents_SelectedRows[5m])", "legendFormat": "selected", "refId": "A" },
        { "expr": "rate(ClickHouseProfileEvents_InsertedRows[5m])", "legendFormat": "inserted", "refId": "B" }
      ]
    },
    {
      "type": "timeseries", "title": "Memory", "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [
        { "expr": "ClickHouseMetrics_MemoryTracking", "legendFormat": "tracked", "refId": "A" },
        { "expr": "ClickHouseAsyncMetrics_MemoryResident", "legendFormat": "resident (RSS)", "refId": "B" },
        { "expr": "ClickHouseAsyncMetrics_jemalloc_resident", "legendFormat": "jemalloc", "refId": "C" }
      ]
    },
    {
      "type": "timeseries", "title": "Disk — default", "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [
        { "expr": "ClickHouseAsyncMetrics_DiskUsed_default", "legendFormat": "used", "refId": "A" },
        { "expr": "ClickHouseAsyncMetrics_DiskTotal_default", "legendFormat": "total", "refId": "B" }
      ]
    },
    {
      "type": "timeseries", "title": "Connections & merges", "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [
        { "expr": "ClickHouseMetrics_TCPConnection", "legendFormat": "tcp conns", "refId": "A" },
        { "expr": "ClickHouseMetrics_HTTPConnection", "legendFormat": "http conns", "refId": "B" },
        { "expr": "ClickHouseMetrics_Merge", "legendFormat": "active merges", "refId": "C" }
      ]
    },
    {
      "type": "timeseries", "title": "Parts", "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [
        { "expr": "ClickHouseMetrics_PartsActive", "legendFormat": "active parts", "refId": "A" },
        { "expr": "ClickHouseAsyncMetrics_MaxPartCountForPartition", "legendFormat": "max parts/partition", "refId": "B" }
      ]
    }
  ]
}
