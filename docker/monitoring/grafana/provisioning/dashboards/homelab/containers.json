{
  "annotations": { "list": [ { "builtIn": 1, "datasource": "-- Grafana --", "enable": true, "hide": true, "iconColor": "rgba(0, 211, 255, 1)", "name": "Annotations & Alerts", "type": "dashboard" } ] },
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["jarvis", "docker", "containers"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "title": "Containers (Docker)",
  "uid": "jarvis-containers",
  "panels": [
    { "type": "stat", "title": "Running Containers", "datasource": "Prometheus", "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "datasource": "Prometheus", "expr": "docker_n_containers_running", "refId": "A" } ] },

    { "type": "stat", "title": "Total Container Memory", "datasource": "Prometheus", "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "decbytes", "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "datasource": "Prometheus", "expr": "sum(docker_container_mem_usage)", "refId": "A" } ] },

    { "type": "stat", "title": "Total Container CPU", "datasource": "Prometheus", "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percent", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 200 }, { "color": "red", "value": 400 } ] } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "datasource": "Prometheus", "expr": "sum(docker_container_cpu_usage_percent)", "refId": "A" } ] },

    { "type": "stat", "title": "OOM Kills / Restarts", "datasource": "Prometheus", "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value_and_name" },
      "targets": [
        { "datasource": "Prometheus", "expr": "sum(docker_container_status_oomkilled)", "legendFormat": "OOM", "refId": "A" },
        { "datasource": "Prometheus", "expr": "sum(docker_container_status_restart_count)", "legendFormat": "Restarts", "refId": "B" } ] },

    { "type": "timeseries", "title": "CPU % by Container", "datasource": "Prometheus", "gridPos": { "h": 10, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "percent", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "datasource": "Prometheus", "expr": "docker_container_cpu_usage_percent", "legendFormat": "{{container_name}}", "refId": "A" } ] },

    { "type": "timeseries", "title": "Memory by Container", "datasource": "Prometheus", "gridPos": { "h": 10, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "decbytes", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "datasource": "Prometheus", "expr": "docker_container_mem_usage", "legendFormat": "{{container_name}}", "refId": "A" } ] },

    { "type": "timeseries", "title": "Network I/O by Container (RX +, TX -)", "datasource": "Prometheus", "gridPos": { "h": 10, "w": 12, "x": 0, "y": 14 },
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": "Prometheus", "expr": "sum by (container_name) (rate(docker_container_net_rx_bytes[5m]))", "legendFormat": "{{container_name}} rx", "refId": "A" },
        { "datasource": "Prometheus", "expr": "-sum by (container_name) (rate(docker_container_net_tx_bytes[5m]))", "legendFormat": "{{container_name}} tx", "refId": "B" } ] },

    { "type": "timeseries", "title": "Block I/O by Container (read +, write -)", "datasource": "Prometheus", "gridPos": { "h": 10, "w": 12, "x": 12, "y": 14 },
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": "Prometheus", "expr": "sum by (container_name) (rate(docker_container_blkio_io_service_bytes_recursive_read[5m]))", "legendFormat": "{{container_name}} read", "refId": "A" },
        { "datasource": "Prometheus", "expr": "-sum by (container_name) (rate(docker_container_blkio_io_service_bytes_recursive_write[5m]))", "legendFormat": "{{container_name}} write", "refId": "B" } ] },

    { "type": "table", "title": "Containers — current usage", "datasource": "Prometheus", "gridPos": { "h": 12, "w": 24, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "custom": { "align": "auto" } }, "overrides": [
        { "matcher": { "id": "byName", "options": "Mem" }, "properties": [ { "id": "unit", "value": "decbytes" } ] },
        { "matcher": { "id": "byName", "options": "Mem %" }, "properties": [ { "id": "unit", "value": "percent" } ] },
        { "matcher": { "id": "byName", "options": "CPU %" }, "properties": [ { "id": "unit", "value": "percent" } ] } ] },
      "options": { "showHeader": true, "sortBy": [ { "displayName": "Mem", "desc": true } ] },
      "targets": [
        { "datasource": "Prometheus", "expr": "docker_container_cpu_usage_percent", "format": "table", "instant": true, "refId": "A" },
        { "datasource": "Prometheus", "expr": "docker_container_mem_usage", "format": "table", "instant": true, "refId": "B" },
        { "datasource": "Prometheus", "expr": "docker_container_mem_usage_percent", "format": "table", "instant": true, "refId": "C" } ],
      "transformations": [
        { "id": "joinByField", "options": { "byField": "container_name", "mode": "outer" } },
        { "id": "organize", "options": {
          "excludeByName": { "Time 1": true, "Time 2": true, "Time 3": true, "__name__ 1": true, "__name__ 2": true, "__name__ 3": true,
            "com_docker_compose_project 1": true, "com_docker_compose_project 2": true, "com_docker_compose_project 3": true,
            "com_docker_compose_service 1": true, "com_docker_compose_service 2": true, "com_docker_compose_service 3": true,
            "container_id 1": true, "container_id 2": true, "container_id 3": true,
            "container_version 1": true, "container_version 2": true, "container_version 3": true,
            "engine_host 1": true, "engine_host 2": true, "engine_host 3": true,
            "host 1": true, "host 2": true, "host 3": true, "instance 1": true, "instance 2": true, "instance 3": true,
            "job 1": true, "job 2": true, "job 3": true, "server_version 1": true, "server_version 2": true, "server_version 3": true,
            "container_status 2": true, "container_status 3": true, "container_image 2": true, "container_image 3": true },
          "renameByName": { "container_name": "Container", "container_image 1": "Image", "container_status 1": "Status",
            "Value #A": "CPU %", "Value #B": "Mem", "Value #C": "Mem %" } } } ] }
  ]
}
