{
  "annotations": { "list": [ { "builtIn": 1, "datasource": "-- Grafana --", "enable": true, "hide": true, "iconColor": "rgba(0, 211, 255, 1)", "name": "Annotations & Alerts", "type": "dashboard" } ] },
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["jarvis", "data", "postgres"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "title": "Postgres",
  "uid": "jarvis-postgres",
  "panels": [
    { "type": "stat", "title": "Status", "datasource": "Prometheus", "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "mappings": [ { "type": "value", "options": { "1": { "text": "UP", "color": "green" }, "0": { "text": "DOWN", "color": "red" } } } ], "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] } }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "datasource": "Prometheus", "expr": "pg_up", "refId": "A" } ] },

    { "type": "gauge", "title": "Connections Used", "datasource": "Prometheus", "gridPos": { "h": 4, "w": 5, "x": 4, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 } ] } }, "overrides": [] },
      "options": { "showThresholdMarkers": true },
      "targets": [ { "datasource": "Prometheus", "expr": "100 * sum(pg_stat_activity_count) / max(pg_settings_max_connections)", "refId": "A" } ] },

    { "type": "gauge", "title": "Cache Hit Ratio", "datasource": "Prometheus", "gridPos": { "h": 4, "w": 5, "x": 9, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 90 }, { "color": "green", "value": 98 } ] } }, "overrides": [] },
      "options": { "showThresholdMarkers": true },
      "targets": [ { "datasource": "Prometheus", "expr": "100 * sum(pg_stat_database_blks_hit) / (sum(pg_stat_database_blks_hit) + sum(pg_stat_database_blks_read))", "refId": "A" } ] },

    { "type": "stat", "title": "Active Queries", "datasource": "Prometheus", "gridPos": { "h": 4, "w": 5, "x": 14, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 20 }, { "color": "red", "value": 50 } ] } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "datasource": "Prometheus", "expr": "sum(pg_stat_activity_count{state=\"active\"})", "refId": "A" } ] },

    { "type": "stat", "title": "Total Size", "datasource": "Prometheus", "gridPos": { "h": 4, "w": 5, "x": 19, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "decbytes", "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "datasource": "Prometheus", "expr": "sum(pg_database_size_bytes{datname!~\"template.*\"})", "refId": "A" } ] },

    { "type": "timeseries", "title": "Connections by State", "datasource": "Prometheus", "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 20, "showPoints": "never", "stacking": { "mode": "normal" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "datasource": "Prometheus", "expr": "sum by (state) (pg_stat_activity_count)", "legendFormat": "{{state}}", "refId": "A" } ] },

    { "type": "timeseries", "title": "Transactions / sec", "datasource": "Prometheus", "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": "Prometheus", "expr": "sum(rate(pg_stat_database_xact_commit[5m]))", "legendFormat": "commits", "refId": "A" },
        { "datasource": "Prometheus", "expr": "sum(rate(pg_stat_database_xact_rollback[5m]))", "legendFormat": "rollbacks", "refId": "B" } ] },

    { "type": "timeseries", "title": "Connections by Database", "datasource": "Prometheus", "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "datasource": "Prometheus", "expr": "sum by (datname) (pg_stat_database_numbackends{datname!~\"template.*\"})", "legendFormat": "{{datname}}", "refId": "A" } ] },

    { "type": "timeseries", "title": "Cache Hit Ratio (5m)", "datasource": "Prometheus", "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [ { "datasource": "Prometheus", "expr": "100 * sum(rate(pg_stat_database_blks_hit[5m])) / (sum(rate(pg_stat_database_blks_hit[5m])) + sum(rate(pg_stat_database_blks_read[5m])))", "legendFormat": "hit %", "refId": "A" } ] },

    { "type": "table", "title": "Database Sizes", "datasource": "Prometheus", "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "decbytes" }, "overrides": [] },
      "options": { "showHeader": true, "sortBy": [ { "displayName": "Size", "desc": true } ] },
      "targets": [ { "datasource": "Prometheus", "expr": "sort_desc(pg_database_size_bytes{datname!~\"template.*\"})", "format": "table", "instant": true, "refId": "A" } ],
      "transformations": [ { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true, "server": true }, "renameByName": { "datname": "Database", "Value": "Size" } } } ] },

    { "type": "timeseries", "title": "Deadlocks & Temp Files (5m)", "datasource": "Prometheus", "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [ { "matcher": { "id": "byName", "options": "temp bytes" }, "properties": [ { "id": "unit", "value": "Bps" }, { "id": "custom.axisPlacement", "value": "right" } ] } ] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": "Prometheus", "expr": "sum(rate(pg_stat_database_deadlocks[5m]))", "legendFormat": "deadlocks/s", "refId": "A" },
        { "datasource": "Prometheus", "expr": "sum(rate(pg_stat_database_temp_bytes[5m]))", "legendFormat": "temp bytes", "refId": "B" } ] }
  ]
}
