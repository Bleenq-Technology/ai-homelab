{
  "uid": "zoomie-workstation",
  "title": "Zoomie Workstation",
  "tags": ["homelab", "zoomie", "windows"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "type": "stat", "title": "Reachable (up)", "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "expr": "up{job=\"zoomie\"}" } ],
      "fieldConfig": { "defaults": { "mappings": [ { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } } ], "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] } } },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat", "title": "Uptime", "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "expr": "system_uptime{host=\"zoomie\"}" } ],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat", "title": "CPU busy", "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "expr": "100 - cpu_usage_idle{host=\"zoomie\",cpu=\"cpu-total\"}" } ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 80 }, { "color": "red", "value": 95 } ] } } },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat", "title": "Memory used", "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "expr": "mem_used_percent{host=\"zoomie\"}" } ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 85 }, { "color": "red", "value": 95 } ] } } },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat", "title": "GPU temp", "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "expr": "nvidia_smi_temperature_gpu{host=\"zoomie\"}" } ],
      "fieldConfig": { "defaults": { "unit": "celsius", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 80 }, { "color": "red", "value": 90 } ] } } },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat", "title": "GPU power", "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "expr": "nvidia_power_draw_watts{host=\"zoomie\"}" } ],
      "fieldConfig": { "defaults": { "unit": "watt", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 250 }, { "color": "red", "value": 290 } ] } } },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "timeseries", "title": "GPU power draw (W) vs limit", "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "nvidia_power_draw_watts{host=\"zoomie\"}", "legendFormat": "draw" },
        { "refId": "B", "expr": "nvidia_power_limit_watts{host=\"zoomie\"}", "legendFormat": "limit" }
      ],
      "fieldConfig": { "defaults": { "unit": "watt", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "type": "timeseries", "title": "GPU temperature (°C)", "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "expr": "nvidia_smi_temperature_gpu{host=\"zoomie\"}", "legendFormat": "GPU" } ],
      "fieldConfig": { "defaults": { "unit": "celsius", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "type": "timeseries", "title": "GPU utilization & fan (%)", "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "nvidia_smi_utilization_gpu{host=\"zoomie\"}", "legendFormat": "GPU util" },
        { "refId": "B", "expr": "nvidia_smi_fan_speed{host=\"zoomie\"}", "legendFormat": "fan" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "type": "timeseries", "title": "GPU VRAM used (MiB)", "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "nvidia_smi_memory_used{host=\"zoomie\"}", "legendFormat": "used" },
        { "refId": "B", "expr": "nvidia_smi_memory_total{host=\"zoomie\"}", "legendFormat": "total" }
      ],
      "fieldConfig": { "defaults": { "unit": "decmbytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "type": "timeseries", "title": "CPU busy (%)", "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "expr": "100 - cpu_usage_idle{host=\"zoomie\",cpu=\"cpu-total\"}", "legendFormat": "CPU" } ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "type": "timeseries", "title": "Memory used (%)", "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "expr": "mem_used_percent{host=\"zoomie\"}", "legendFormat": "mem" } ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "type": "timeseries", "title": "Disk used (%)", "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "expr": "disk_used_percent{host=\"zoomie\"}", "legendFormat": "{{path}}" } ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "type": "timeseries", "title": "Disk I/O (B/s)", "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "rate(diskio_read_bytes{host=\"zoomie\"}[5m])", "legendFormat": "read {{name}}" },
        { "refId": "B", "expr": "rate(diskio_write_bytes{host=\"zoomie\"}[5m])", "legendFormat": "write {{name}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "type": "timeseries", "title": "Reachability / reboots (up + uptime)", "gridPos": { "h": 7, "w": 24, "x": 0, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "up drops to 0 when zoomie is unreachable (crash/reboot window); system_uptime sawtooths down at each boot.",
      "targets": [
        { "refId": "A", "expr": "up{job=\"zoomie\"}", "legendFormat": "up" },
        { "refId": "B", "expr": "system_uptime{host=\"zoomie\"} / 3600", "legendFormat": "uptime (h)" }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 15 } } }
    }
  ]
}
